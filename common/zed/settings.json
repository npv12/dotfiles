{
  "diff_view_style": "split",
  "edit_predictions": {
    "mode": "eager",
    "provider": "zed"
  },
  "git": {
    "inline_blame": {}
  },
  "ui_font_family": "Inter Variable",
  "buffer_font_weight": 500.0,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "language_models": {
    "openai_compatible": {
      "Minimax": {
        "api_url": "https://api.minimax.io/v1",
        "available_models": [
          {
            "name": "MiniMax-M2.7",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          }
        ]
      }
    }
  },
  "agent_servers": {},
  "agent": {
    "tool_permissions": {
      "tools": {
        "web_search": {
          "default": "allow"
        }
      }
    },
    "default_model": {
      "enable_thinking": false,
      "provider": "Minimax",
      "model": "MiniMax-M2.7"
    },
    "favorite_models": [
      {
        "provider": "Synthetic",
        "model": "hf:moonshotai/Kimi-K2.5",
        "enable_thinking": true
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5-mini",
        "enable_thinking": false
      },
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4-6",
        "enable_thinking": false
      },
      {
        "provider": "zed.dev",
        "model": "claude-haiku-4-5",
        "enable_thinking": false
      }
    ],
    "model_parameters": []
  },
  "git_panel": {
    "sort_by_path": true,
    "tree_view": false
  },
  "base_keymap": "VSCode",
  "icon_theme": {
    "mode": "light",
    "light": "JetBrains New UI Icons (Light)",
    "dark": "JetBrains New UI Icons (Dark)"
  },
  "format_on_save": "off",
  "autosave": {
    "after_delay": {
      "milliseconds": 500
    }
  },
  "terminal": {
    "font_family": "MesloLGS NF",
    "font_size": 14,
    "line_height": "standard"
  },
  "when_closing_with_no_tabs": "keep_window_open",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "ui_font_size": 17.0,
  "buffer_font_size": 16,
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte (peach)",
    "dark": "Catppuccin Mocha (peach)"
  }
}
